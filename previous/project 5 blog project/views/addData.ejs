<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Add Form</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #1f1c2c, #928dab);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .card {
            border-radius: 15px;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-lg border-0">
                    <div class="card-body p-4">

                        <h3 class="text-center fw-bold mb-3 text-primary">
                            👋 Hello <%= name %> Add your blog
                        </h3>
                        

                        <form action="/addData" method="post" enctype="multipart/form-data">

                            <div class="mb-3">
                                <label class="form-label"> Name</label>
                                <input 
                                    type="text" 
                                    name="name" 
                                    class="form-control"
                                    placeholder="Enter student name"
                                    required
                                >
                            </div>
                            <div class="mb-3">
                                <label class="form-label"> COntent</label>
                    
                                <textarea  type="text" 
                                    name="content" 
                                    class="form-control"
                                    placeholder="Enter  content"
                                    required></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Image URL</label>
                                <input 
                                    type="file" 
                                    name="img" 
                                    class="form-control"
                                    placeholder="Enter image URL"
                                >
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary">
                                    ➕ Submit
                                </button>

                                <a href="/view" class="btn btn-outline-secondary">
                                    👀 View All Data
                                </a>
                            </div>

                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
