<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Update Student</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #1f1c2c, #928dab);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .card {
            border-radius: 15px;
        }
        .student-img {
            width: 90px;
            height: 90px;
            object-fit: cover;
            border-radius: 10px;
            border: 2px solid #dc3545;
        }
    </style>
</head>

<body>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="card shadow-lg border-0">
                <div class="card-body p-4">

                    <h3 class="text-center fw-bold text-danger mb-3">
                        ✏ Update Student
                    </h3>

                    <p class="text-center text-muted mb-4">
                        Hello <%= name %>, edit student details below
                    </p>

                    <form action="/updatedData" method="post" enctype="multipart/form-data">

                        <!-- Hidden ID -->
                        <input type="hidden" name="id" value="<%= updated._id %>">

                        <div class="mb-3">
                            <label class="form-label"> Name</label>
                            <input
                                type="text"
                                name="name"
                                class="form-control"
                                value="<%= updated.name %>"
                                
                            >
                        </div>

                          <div class="mb-3">
                                <label class="form-label"> Content</label>
                    
                                <textarea  type="text" 
                                    name="content" 
                                    class="form-control"
                                    placeholder="Enter  content"
                                                                    value="<%= updated.content %>"

                                    ></textarea>
                            </div>

                        <div class="mb-3">
                            <label class="form-label">Image URL</label>
                            <input
                                type="file"
                                name="img"
                                class="form-control"
                                value="<%= updated.img %>"
                            >
                        </div>

                        <div class="text-center mb-3">
                            <img src="../<%= updated.img %>" alt="Student Image" class="student-img">
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-danger">
                                🔄 Update Student
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
