<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Blog Home</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">
    <%- include("navbar.ejs")%>

<!-- Header -->
<div class="container text-center mt-5">

<h1 class="fw-bold">Latest Blog Posts</h1>

<p class="text-muted">
Read the latest articles from our blog
</p>

</div>

<!-- Blog Section -->

<div class="container my-4">

<div class="row g-4">

<% allData.map((e)=>{ %>

<div class="col-md-4">

<div class="card shadow-sm h-100">

<img src="/<%= e.image %>" class="card-img-top" style="height:220px; object-fit:cover;">

<div class="card-body">

<h5 class="card-title">
<%= e.title %>
</h5>

<p class="card-text text-muted">
<%= e.description.substring(0,120) %>...
</p>

<p class="text-secondary">
Category : <%= e.category %>
</p>

<p class="text-secondary">
Author : <%= e.author %>
</p>

</div>


</div>

</div>

<% }) %>

</div>

</div>

    <%- include("footer.ejs")%>


</body>
</html>